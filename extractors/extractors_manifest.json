      "interface": {
        "detect": "detect(zip_path: Path) -> bool",
        "extract": "extract(zip_path: Path, out_dir: Path) -> list[dict]"
      },
      "detect_mode": "file_provided",
      "input": "user_export_zip",
      "output_schema": {
        "platform": "string — 'Facebook' or 'Instagram'",
        "messages": "array",
        "retrieved_at": "string"
      },
      "tags": ["meta", "facebook", "instagram", "import"]
    },
    {
